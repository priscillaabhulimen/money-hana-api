# Database configuration for the application. Update the values with your actual database credentials.
DATABASE_URL=postgresql+asyncpg://<username>:<password>@<host>:<port>/<database-name>
ALLOWED_ORIGINS=http://localhost:3000

# Authentication configuration. Update the values with your actual authentication credentials.
AUTH_SECRET_KEY=<your-secret-key>
AUTH_ALGORITHM=<your-algorithm>
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=<token-expiration-time-in-minutes>

EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@yourdomain.com
FRONTEND_VERIFY_URL=http://localhost:3000/verify-email
RESEND_API_KEY=<your-resend-api-key>
# Optional: override recipient for provider sandbox/testing limitations.
# EMAIL_TEST_RECIPIENT=you@example.com